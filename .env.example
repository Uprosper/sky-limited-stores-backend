# Copy this file to .env and fill in your real values. Never commit .env to GitHub.

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/skylimitedstores

# Secret used to sign JWT tokens — use a long random string
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Port the server listens on
PORT=5000

# Comma-separated list of allowed origins for CORS, or * for all
# e.g. https://yourusername.github.io
CORS_ORIGIN=*

# Paystack — get these from your Paystack dashboard (Settings > API Keys & Webhooks)
# Use the TEST keys while developing, switch to LIVE keys once ready for real payments
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where Paystack redirects the customer after payment (a page on your frontend)
PAYSTACK_CALLBACK_URL=http://localhost:5000/order-success.html
